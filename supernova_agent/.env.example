# ── Ethereum RPC ──────────────────────────────────────────────
ETH_RPC_URL=https://eth.llamarpc.com

# ── Wallet (KEEP SECRET!) ────────────────────────────────────
PRIVATE_KEY=
WALLET_ADDRESS=

# ── Gemini AI (에이전트 두뇌) ────────────────────────────────
# Google AI Studio에서 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Telegram Bot (optional) ──────────────────────────────────
SN_TELEGRAM_BOT_TOKEN=
SN_TELEGRAM_CHAT_ID=

# ── Agent Parameters ─────────────────────────────────────────
# Scan interval in seconds (default: 300 = 5 minutes)
SCAN_INTERVAL_SECONDS=300

# Minimum APR improvement (%) to trigger migration (default: 2.0)
MIN_APR_IMPROVEMENT=2.0

# Maximum gas price in gwei (skip migration if higher)
MAX_GAS_PRICE_GWEI=50

# Slippage tolerance in % (default: 0.5)
SLIPPAGE_TOLERANCE=0.5

# Minimum pool TVL in USD to consider (default: 10000)
MIN_POOL_TVL_USD=10000

# Max portion of wallet to deploy (0.0-1.0)
MAX_DEPLOY_RATIO=0.95

# Dry-run mode: true = simulate only, false = execute real transactions
DRY_RUN=true
